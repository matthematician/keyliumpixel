{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "keyliumpixel",
  "compatibility_date": "2026-05-25",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "directory": "./dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
